rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - name: string (optional)
    //   - email: string (required)
    //   - preferredLanguage: string (optional)
    //   - location: string (optional)
    //   - role: string (enum: user, admin)
    //
    // Collection: reports
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - imageUrl: string (required)
    //   - detectionResult: string (required)
    //   - confidence: number (optional)
    //   - treatment: string (optional)
    //   - weatherContext: map (optional)
    //   - timestamp: timestamp (required)
    //   - cropType: string (optional)
    //
    // Collection: chats
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - role: string (enum: user, model)
    //   - text: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "jobinfo.twinkal@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    function isValidReport(data) {
      return data.keys().hasAll(['userId', 'imageUrl', 'detectionResult', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.imageUrl is string &&
             data.detectionResult is string &&
             data.timestamp is timestamp;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'role', 'text', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.role in ['user', 'model'] &&
             data.text is string &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow update: if false; // Reports are immutable for now
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if false;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
